<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:compat="clr-namespace:SakuraEDL.Views.Controls">

        <!-- Neo-black neumorphic theme tuned for the SakuraEDL main shell -->
    <LinearGradientBrush x:Key="ThemeHostBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#171B22" Offset="0" />
        <GradientStop Color="#10141B" Offset="1" />
    </LinearGradientBrush>
    <RadialGradientBrush x:Key="ThemeOrbBrush" Center="0.5,0.5" GradientOrigin="0.42,0.42" RadiusX="0.62" RadiusY="0.62">
        <GradientStop Color="#12FFFFFF" Offset="0" />
        <GradientStop Color="#00FFFFFF" Offset="1" />
    </RadialGradientBrush>
    <LinearGradientBrush x:Key="ThemeWindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F01A1F27" Offset="0" />
        <GradientStop Color="#EC131820" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ThemeShellGlassBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#DA1D232C" Offset="0" />
        <GradientStop Color="#C4171C24" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ThemeSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#262D37" Offset="0" />
        <GradientStop Color="#1F2630" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ThemeSurfaceAltBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#222933" Offset="0" />
        <GradientStop Color="#1B222B" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ThemeInsetBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#171C23" Offset="0" />
        <GradientStop Color="#11161D" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ThemeRaisedBorderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#38434E5C" Offset="0" />
        <GradientStop Color="#740A0D12" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ThemeInsetBorderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#8A090C11" Offset="0" />
        <GradientStop Color="#304A5768" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ThemeForegroundBrush" Color="#E8EEF7" />
    <SolidColorBrush x:Key="ThemeMutedForegroundBrush" Color="#95A1B2" />
    <SolidColorBrush x:Key="ThemeBorderBrush" Color="#242C38" />
    <SolidColorBrush x:Key="ThemeFrameBorderBrush" Color="#313B48" />
    <SolidColorBrush x:Key="ThemeAccentBrush" Color="#7FA4D8" />
    <SolidColorBrush x:Key="ThemeAccentForegroundBrush" Color="#111A29" />
    <SolidColorBrush x:Key="ThemeAccentSoftBrush" Color="#227FA4D8" />
    <SolidColorBrush x:Key="ThemeAccentMediumBrush" Color="#367FA4D8" />
    <SolidColorBrush x:Key="ThemeAccentStrongBrush" Color="#4F7FA4D8" />
    <SolidColorBrush x:Key="ThemeProgressTrackBrush" Color="#30000000" />
    <LinearGradientBrush x:Key="ThemeProgressFillBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#5F83B6" Offset="0" />
        <GradientStop Color="#7FA4D8" Offset="0.62" />
        <GradientStop Color="#96B8E5" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ThemeInputBackgroundBrush" Color="#1A212B" />
    <SolidColorBrush x:Key="ThemeInputBackgroundHoverBrush" Color="#202733" />
    <SolidColorBrush x:Key="ThemeInputBorderBrush" Color="#2F3948" />
    <SolidColorBrush x:Key="ThemeInputFocusBorderBrush" Color="#8DB6EE" />
    <LinearGradientBrush x:Key="ThemeMenuBarBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#232A36" Offset="0" />
        <GradientStop Color="#1B222C" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ThemeMenuPopupBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#202733" Offset="0" />
        <GradientStop Color="#171D27" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ThemeMenuHoverBrush" Color="#2A3341" />
    <SolidColorBrush x:Key="ThemeMenuSelectedBrush" Color="#337FA4D8" />
    <SolidColorBrush x:Key="ThemeSelectionBrush" Color="#437FA4D8" />
    <SolidColorBrush x:Key="ThemeSelectionInactiveBrush" Color="#2E2A3340" />
    <SolidColorBrush x:Key="ThemeDangerBrush" Color="#C84747" />
    <SolidColorBrush x:Key="ThemeDangerHoverBrush" Color="#D45454" />
    <SolidColorBrush x:Key="ThemeDangerPressedBrush" Color="#A53A3A" />
    <SolidColorBrush x:Key="ThemeDangerBorderBrush" Color="#E36A6A" />
    <SolidColorBrush x:Key="ButtonSelectBrush" Color="#3D7FA4D8" />
    <SolidColorBrush x:Key="DarkBrush" Color="#151B24" />

    <!-- Force default WPF selection/menu chrome to follow dark theme -->
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#1C232E" />
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#E8EEF7" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#1F2631" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#E8EEF7" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#121821" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#E8EEF7" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#437FA4D8" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#E8EEF7" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#2E2A3340" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#E8EEF7" />

    <DropShadowEffect x:Key="ThemeFrameShadow" Color="#CF05070B" BlurRadius="44" ShadowDepth="0" Opacity="0.72" />
    <SolidColorBrush x:Key="ThemeDividerBrush" Color="#26334152" />
    <SolidColorBrush x:Key="ThemePanelInnerStrokeBrush" Color="#1BE8EEF8" />
    <LinearGradientBrush x:Key="ThemeTabHeaderOverlayBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1AFFFFFF" Offset="0" />
        <GradientStop Color="#00000000" Offset="1" />
    </LinearGradientBrush>

    <Style TargetType="{x:Type Window}">
        <Setter Property="Background" Value="{DynamicResource ThemeWindowBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource ThemeSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="15,7" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid>
                        <Border x:Name="surfaceShadow"
                                Margin="3,3,0,0"
                                CornerRadius="11"
                                Background="#01000000"
                                Opacity="0.58">
                            <Border.Effect>
                                <DropShadowEffect Color="#C7000000"
                                                  BlurRadius="16"
                                                  ShadowDepth="0"
                                                  Opacity="0.62" />
                            </Border.Effect>
                        </Border>
                        <Border x:Name="surface"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <Grid>
                                <Border x:Name="innerStroke"
                                        Margin="1"
                                        CornerRadius="9"
                                        BorderThickness="1"
                                        BorderBrush="#18FFFFFF" />
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="surface" Property="Background" Value="{DynamicResource ThemeSurfaceAltBrush}" />
                            <Setter TargetName="surface" Property="BorderBrush" Value="{DynamicResource ThemeInputFocusBorderBrush}" />
                            <Setter TargetName="innerStroke" Property="BorderBrush" Value="#24FFFFFF" />
                            <Setter TargetName="surfaceShadow" Property="Opacity" Value="0.72" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="surface" Property="Background" Value="{DynamicResource ThemeInsetBrush}" />
                            <Setter TargetName="surface" Property="BorderBrush" Value="{DynamicResource ThemeInsetBorderBrush}" />
                            <Setter TargetName="innerStroke" Property="BorderBrush" Value="#0AFFFFFF" />
                            <Setter TargetName="surfaceShadow" Property="Opacity" Value="0.35" />
                            <Setter Property="Foreground" Value="{DynamicResource ThemeAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="surface" Property="BorderBrush" Value="{DynamicResource ThemeInputFocusBorderBrush}" />
                            <Setter TargetName="surfaceShadow" Property="Opacity" Value="0.68" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="surface" Property="Opacity" Value="0.5" />
                            <Setter TargetName="surfaceShadow" Property="Opacity" Value="0.2" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DangerButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource ThemeDangerBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeDangerBorderBrush}" />
        <Setter Property="Foreground" Value="#FFF7F7" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="surface"
                            CornerRadius="9"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="surface" Property="Background" Value="{DynamicResource ThemeDangerHoverBrush}" />
                            <Setter TargetName="surface" Property="BorderBrush" Value="#FFFF8C8C" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="surface" Property="Background" Value="{DynamicResource ThemeDangerPressedBrush}" />
                            <Setter TargetName="surface" Property="BorderBrush" Value="#FFFF7C7C" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="surface" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TitleBarButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="Background" Value="#1E000000" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
    </Style>

    <Style x:Key="TitleBarCloseButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource TitleBarButtonStyle}">
        <Setter Property="Background" Value="#2A5A1A1A" />
        <Setter Property="BorderBrush" Value="#66E06A6A" />
        <Setter Property="Foreground" Value="#FFF3DADA" />
    </Style>

    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CaretBrush" Value="{DynamicResource ThemeAccentBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource ThemeSelectionBrush}" />
        <Setter Property="SelectionOpacity" Value="0.72" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Grid>
                        <Border x:Name="surfaceShadow"
                                Margin="2,2,0,0"
                                CornerRadius="11"
                                Background="#01000000"
                                Opacity="0.5">
                            <Border.Effect>
                                <DropShadowEffect Color="#B6000000"
                                                  BlurRadius="13"
                                                  ShadowDepth="0"
                                                  Opacity="0.58" />
                            </Border.Effect>
                        </Border>
                        <Border x:Name="surface"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Border x:Name="innerStroke"
                                        Margin="1"
                                        CornerRadius="9"
                                        BorderThickness="1"
                                        BorderBrush="#12FFFFFF" />
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                            </Grid>
                        </Border>
                        <TextBlock x:Name="WatermarkText"
                                   Margin="14,0,34,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                   Text="{TemplateBinding Tag}"
                                   Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value="" />
                                <Condition Property="IsKeyboardFocused" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="WatermarkText" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="surface" Property="Background" Value="{DynamicResource ThemeInputBackgroundHoverBrush}" />
                            <Setter TargetName="surface" Property="BorderBrush" Value="{DynamicResource ThemeRaisedBorderBrush}" />
                            <Setter TargetName="innerStroke" Property="BorderBrush" Value="#18FFFFFF" />
                            <Setter TargetName="surfaceShadow" Property="Opacity" Value="0.62" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="surface" Property="BorderBrush" Value="{DynamicResource ThemeInputFocusBorderBrush}" />
                            <Setter TargetName="surface" Property="Background" Value="{DynamicResource ThemeInputBackgroundHoverBrush}" />
                            <Setter TargetName="innerStroke" Property="BorderBrush" Value="#22FFFFFF" />
                            <Setter TargetName="surfaceShadow" Property="Opacity" Value="0.72" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="surface" Property="Opacity" Value="0.55" />
                            <Setter TargetName="surfaceShadow" Property="Opacity" Value="0.2" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="{DynamicResource ThemeSurfaceAltBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="13,7" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <Border x:Name="ComboShadow"
                                Margin="2,2,0,0"
                                CornerRadius="11"
                                Background="#01000000"
                                Opacity="0.54">
                            <Border.Effect>
                                <DropShadowEffect Color="#B6000000"
                                                  BlurRadius="13"
                                                  ShadowDepth="0"
                                                  Opacity="0.6" />
                            </Border.Effect>
                        </Border>
                        <Border x:Name="OuterBorder"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" />
                        <Grid Margin="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="ContentSite"
                                              Grid.Column="0"
                                              Margin="12,0,8,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              RecognizesAccessKey="True"
                                              IsHitTestVisible="False" />

                            <TextBox x:Name="PART_EditableTextBox"
                                     Grid.Column="0"
                                     Margin="12,0,8,0"
                                     Background="Transparent"
                                     Foreground="{TemplateBinding Foreground}"
                                     BorderThickness="0"
                                     Visibility="Hidden"
                                     VerticalContentAlignment="Center" />

                            <TextBlock x:Name="PlaceholderText"
                                       Grid.Column="0"
                                       Margin="12,0,8,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                       Text="{TemplateBinding Tag}"
                                       Visibility="Collapsed" />

                            <Border x:Name="DropZone"
                                    Grid.Column="1"
                                    Margin="0,1,1,1"
                                    CornerRadius="0,9,9,0"
                                    Background="#14000000"
                                    BorderBrush="{DynamicResource ThemeInsetBorderBrush}"
                                    BorderThickness="1,0,0,0" />

                            <ToggleButton x:Name="DropDownToggle"
                                          Grid.Column="1"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <Path Width="10"
                                      Height="7"
                                      Stretch="Fill"
                                      Data="M 1 1 L 5.5 6.5 L 10 1"
                                      Stroke="{DynamicResource ThemeForegroundBrush}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            </ToggleButton>
                        </Grid>

                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade"
                               IsOpen="{TemplateBinding IsDropDownOpen}">
                            <Border x:Name="PopupBorder"
                                    Margin="0,8,0,0"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Padding="6"
                                    CornerRadius="12"
                                    Background="{DynamicResource ThemeMenuPopupBrush}"
                                    BorderBrush="{DynamicResource ThemeRaisedBorderBrush}"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="#BC000000"
                                                      BlurRadius="24"
                                                      ShadowDepth="0"
                                                      Opacity="0.56" />
                                </Border.Effect>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="SelectedIndex" Value="-1" />
                                <Condition Property="IsEditable" Value="False" />
                                <Condition Property="IsKeyboardFocusWithin" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="PopupBorder" Property="MinHeight" Value="24" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource ThemeSurfaceBrush}" />
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource ThemeInputFocusBorderBrush}" />
                            <Setter TargetName="DropZone" Property="Background" Value="#1B000000" />
                            <Setter TargetName="ComboShadow" Property="Opacity" Value="0.68" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource ThemeInputFocusBorderBrush}" />
                            <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource ThemeInsetBrush}" />
                            <Setter TargetName="DropZone" Property="Background" Value="{DynamicResource ThemeAccentSoftBrush}" />
                            <Setter TargetName="ComboShadow" Property="Opacity" Value="0.74" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="OuterBorder" Property="Opacity" Value="0.5" />
                            <Setter TargetName="DropZone" Property="Opacity" Value="0.4" />
                            <Setter TargetName="ComboShadow" Property="Opacity" Value="0.2" />
                        </Trigger>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger SourceName="DropDownToggle" Property="IsChecked" Value="True">
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource ThemeInputFocusBorderBrush}" />
                            <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource ThemeInsetBrush}" />
                            <Setter TargetName="DropZone" Property="Background" Value="{DynamicResource ThemeAccentSoftBrush}" />
                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ComboShadow" Property="Opacity" Value="0.78" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="ItemBorder"
                            Margin="1"
                            CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#1D1A1F25" />
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#26000000" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ThemeMenuSelectedBrush}" />
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource ThemeInputFocusBorderBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ItemBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type Menu}">
        <Setter Property="Background" Value="{DynamicResource ThemeMenuBarBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeRaisedBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Menu}">
                    <Border CornerRadius="11"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Border.Effect>
                            <DropShadowEffect Color="#A6000000"
                                              BlurRadius="12"
                                              ShadowDepth="0"
                                              Opacity="0.5" />
                        </Border.Effect>
                        <Grid>
                            <Border Margin="1"
                                    CornerRadius="10"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource ThemePanelInnerStrokeBrush}" />
                            <Border Height="1"
                                    Margin="12,0,12,1"
                                    VerticalAlignment="Bottom"
                                    Background="{DynamicResource ThemeInsetBorderBrush}"
                                    Opacity="0.95" />
                            <ItemsPresenter Margin="4,2,4,2" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ContextMenu}">
        <Setter Property="Background" Value="{DynamicResource ThemeMenuPopupBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeRaisedBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6" />
    </Style>

    <Style TargetType="{x:Type MenuItem}">
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="13,6" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="ItemChrome"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <DockPanel LastChildFill="True">
                                    <Path x:Name="SubmenuArrow"
                                          DockPanel.Dock="Right"
                                          Margin="10,0,2,0"
                                          Data="M 0 0 L 4 4 L 0 8"
                                          Stroke="{DynamicResource ThemeMutedForegroundBrush}"
                                          StrokeThickness="1.7"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Visibility="Collapsed"
                                          VerticalAlignment="Center" />
                                    <ContentPresenter x:Name="IconHost"
                                                      DockPanel.Dock="Left"
                                                      Margin="2,0,8,0"
                                                      VerticalAlignment="Center"
                                                      ContentSource="Icon" />
                                    <ContentPresenter x:Name="HeaderHost"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True"
                                                      ContentSource="Header" />
                                </DockPanel>
                                <Border x:Name="TopLevelIndicator"
                                        Height="2"
                                        Margin="10,0,10,1"
                                        VerticalAlignment="Bottom"
                                        CornerRadius="2"
                                        Background="{DynamicResource ThemeAccentBrush}"
                                        Opacity="0"
                                        Visibility="Collapsed" />
                            </Grid>
                        </Border>

                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade"
                               IsOpen="{TemplateBinding IsSubmenuOpen}"
                               Placement="Right">
                            <Border x:Name="PopupChrome"
                                    Margin="8,2,0,0"
                                    MinWidth="210"
                                    Padding="6"
                                    CornerRadius="10"
                                    Background="{DynamicResource ThemeMenuPopupBrush}"
                                    BorderBrush="{DynamicResource ThemeRaisedBorderBrush}"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="#BC000000"
                                                      BlurRadius="22"
                                                      ShadowDepth="0"
                                                      Opacity="0.58" />
                                </Border.Effect>
                                <StackPanel IsItemsHost="True"
                                            KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Role" Value="TopLevelHeader">
                            <Setter Property="Padding" Value="14,6" />
                            <Setter TargetName="ItemChrome" Property="CornerRadius" Value="8" />
                            <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                            <Setter TargetName="PopupChrome" Property="Margin" Value="0,8,0,0" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="TopLevelIndicator" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Role" Value="TopLevelItem">
                            <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Role" Value="SubmenuItem">
                            <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource ThemeMenuHoverBrush}" />
                            <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource ThemeRaisedBorderBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
                            <Setter TargetName="SubmenuArrow" Property="Stroke" Value="{DynamicResource ThemeAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource ThemeMenuSelectedBrush}" />
                            <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource ThemeInputFocusBorderBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Role" Value="TopLevelHeader" />
                                <Condition Property="IsHighlighted" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TopLevelIndicator" Property="Opacity" Value="0.55" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Role" Value="TopLevelHeader" />
                                <Condition Property="IsSubmenuOpen" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TopLevelIndicator" Property="Opacity" Value="1" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ItemChrome" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
        <Setter Property="Margin" Value="0,0,14,8" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <StackPanel Orientation="Horizontal" SnapsToDevicePixels="True">
                        <Border x:Name="CheckBoxBorder"
                                Width="16"
                                Height="16"
                                VerticalAlignment="Center"
                                CornerRadius="4"
                                Background="{DynamicResource ThemeInputBackgroundBrush}"
                                BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                BorderThickness="1">
                            <Path x:Name="CheckMark"
                                  Width="10"
                                  Height="8"
                                  Margin="0,0,0,1"
                                  Stretch="Fill"
                                  Data="M 1 4.5 L 3.8 7.3 L 9 1.6"
                                  Stroke="{DynamicResource ThemeAccentForegroundBrush}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Visibility="Collapsed"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        </Border>
                        <ContentPresenter Margin="8,0,0,0"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource ThemeInputFocusBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckBoxBorder" Property="Background" Value="{DynamicResource ThemeAccentBrush}" />
                            <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}" />
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="CheckBoxBorder" Property="Opacity" Value="0.45" />
                            <Setter Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
        <Setter Property="Margin" Value="0,0,14,8" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <StackPanel Orientation="Horizontal" SnapsToDevicePixels="True">
                        <Border x:Name="RadioBorder"
                                Width="16"
                                Height="16"
                                VerticalAlignment="Center"
                                CornerRadius="8"
                                Background="{DynamicResource ThemeInputBackgroundBrush}"
                                BorderBrush="{DynamicResource ThemeInputBorderBrush}"
