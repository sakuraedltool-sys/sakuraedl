                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <compat:CompatTextBox x:Name="input9" Grid.Column="0" Margin="0,0,8,0" Tag="rawprogram.xml path" KeyboardNavigation.TabIndex="113" />
                                    <compat:CompatTextBox x:Name="input7" Grid.Column="1" Margin="8,0,0,0" Tag="patch.xml path" KeyboardNavigation.TabIndex="120" />
                                </Grid>
                                <Grid Grid.Row="3" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <compat:CompatTextBox x:Name="input6" Grid.Column="0" Margin="0,0,8,0" Tag="Partition image file path" KeyboardNavigation.TabIndex="122" />
                                    <compat:CompatButton x:Name="button4" Grid.Column="1" MinWidth="132" KeyboardNavigation.TabIndex="121" Content="Browse" />
                                </Grid>
                                <compat:CompatGroupBox x:Name="uiGroupBox4" Grid.Row="4" Margin="0,10,0,0" KeyboardNavigation.TabIndex="100" Header="Partition Table">
                                    <Grid Background="Transparent">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <compat:CompatCheckBox x:Name="checkbox13" Width="21" Height="21" Margin="6,0,0,0" KeyboardNavigation.TabIndex="14" FontFamily="Segoe UI" FontSize="9" HorizontalAlignment="Left" VerticalAlignment="Top" />
                                        <compat:CompatListView x:Name="listView2" Grid.Row="1" Margin="0,4,0,0" KeyboardNavigation.TabIndex="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" SelectionMode="Extended">
                                            <compat:CompatListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="Background" Value="{Binding RowBackground}" />
                                                    <Setter Property="Foreground" Value="{Binding RowForeground}" />
                                                </Style>
                                            </compat:CompatListView.ItemContainerStyle>
                                            <compat:CompatListView.View>
                                                <GridView>
                                                    <GridViewColumn x:Name="columnHeader10" Header="      Partition" Width="120">
                                                        <GridViewColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <compat:CompatCheckBox Margin="0,0,6,0" VerticalAlignment="Center" IsChecked="{Binding IsChecked, Mode=TwoWay}" />
                                                                    <TextBlock VerticalAlignment="Center" Text="{Binding Column0}" />
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </GridViewColumn.CellTemplate>
                                                    </GridViewColumn>
                                                    <GridViewColumn x:Name="columnHeader11" Header="LUN" Width="120" DisplayMemberBinding="{Binding Column1}" />
                                                    <GridViewColumn x:Name="columnHeader12" Header="Size" Width="120" DisplayMemberBinding="{Binding Column2}" />
                                                    <GridViewColumn x:Name="columnHeader13" Header="Start Sector" Width="120" DisplayMemberBinding="{Binding Column3}" />
                                                    <GridViewColumn x:Name="columnHeader14" Header="End Sector" Width="120" DisplayMemberBinding="{Binding Column4}" />
                                                    <GridViewColumn x:Name="columnHeader15" Header="Sector Count" Width="120" DisplayMemberBinding="{Binding Column5}" />
                                                    <GridViewColumn x:Name="columnHeader16" Header="Start Address" Width="120" DisplayMemberBinding="{Binding Column6}" />
                                                    <GridViewColumn x:Name="columnHeader17" Header="End Address" Width="120" DisplayMemberBinding="{Binding Column7}" />
                                                    <GridViewColumn x:Name="columnHeader18" Header="File Path" Width="120" DisplayMemberBinding="{Binding Column8}" />
                                                </GridView>
                                            </compat:CompatListView.View>
                                        </compat:CompatListView>
                                    </Grid>
                                </compat:CompatGroupBox>
                                <WrapPanel Grid.Row="5" Margin="0,8,0,0">
                                    <compat:CompatCheckBox x:Name="checkbox15" KeyboardNavigation.TabIndex="105" Content="Auto Reboot" />
                                    <compat:CompatCheckBox x:Name="checkbox12" KeyboardNavigation.TabIndex="107" Content="Skip Bootloader" />
                                    <compat:CompatCheckBox x:Name="checkbox11" KeyboardNavigation.TabIndex="106" Content="Generate XML" />
                                    <compat:CompatCheckBox x:Name="checkbox20" KeyboardNavigation.TabIndex="109" Content="Keep Data" />
                                    <compat:CompatCheckBox x:Name="checkbox16" KeyboardNavigation.TabIndex="108" Content="Protect Partition" />
                                    <compat:CompatCheckBox x:Name="checkbox17" KeyboardNavigation.TabIndex="111" Content="oldoneplus" />
                                    <compat:CompatCheckBox x:Name="checkbox19" KeyboardNavigation.TabIndex="110" Content="oplus" />
                                    <compat:CompatCheckBox x:Name="checkbox18" KeyboardNavigation.TabIndex="112" Content="MetaSuper" />
