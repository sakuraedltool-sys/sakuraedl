                                        <compat:CompatComboBoxItem Content="[VIP] SM8735 - Snapdragon 8SGen4" />
                                        <compat:CompatComboBoxItem Content="[VIP] SM8650 - Snapdragon 8Gen3" />
                                        <compat:CompatComboBoxItem Content="[VIP] SM8550_1 - Snapdragon 8Gen2 V2.6" />
                                        <compat:CompatComboBoxItem Content="[VIP] SM8550_2 - Snapdragon 8Gen2 V2.7" />
                                        <compat:CompatComboBoxItem Content="[VIP] SM8475 - Snapdragon 8+Gen1" />
                                        <compat:CompatComboBoxItem Content="[VIP] SM8450 - Snapdragon 8Gen1" />
                                        <compat:CompatComboBoxItem Content="[VIP] SM8350 - Snapdragon 888/888+" />
                                        <compat:CompatComboBoxItem Content="[VIP] SM7550 - Snapdragon 7+Gen3" />
                                        <compat:CompatComboBoxItem Content="[VIP] SM7475 - Snapdragon 7+Gen2" />
                                        <compat:CompatComboBoxItem Content="[VIP] SM7450 - Snapdragon 7Gen1" />
                                        <compat:CompatComboBoxItem Content="[VIP] SM7325 - Snapdragon 6G1/7SG2" />
                                        <compat:CompatComboBoxItem Content="[VIP] SM6375 - Snapdragon 695/6SGen3" />
                                        <compat:CompatComboBoxItem Content="[VIP] SM6225 - Snapdragon 480" />
                                        <compat:CompatComboBoxItem Content="[VIP] SM6115 - Snapdragon 460" />
