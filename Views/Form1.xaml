                                        <compat:CompatButton x:Name="uiButton7" Margin="0,0,8,8" MinWidth="150" KeyboardNavigation.TabIndex="103" FontFamily="Segoe UI" FontSize="10.5" Foreground="{DynamicResource ThemeForegroundBrush}" Content="Read Partition" />
                                        <compat:CompatButton x:Name="uiButton8" Margin="0,0,8,8" MinWidth="150" KeyboardNavigation.TabIndex="102" FontFamily="Segoe UI" FontSize="10.5" Foreground="{DynamicResource ThemeForegroundBrush}" Content="Write Partition" />
                                        <compat:CompatButton x:Name="uiButton9" Margin="0,0,8,8" MinWidth="150" KeyboardNavigation.TabIndex="101" FontFamily="Segoe UI" FontSize="10.5" Foreground="{DynamicResource ThemeForegroundBrush}" Content="Erase Partition" />
                                    </WrapPanel>
                                    <compat:CompatComboBox x:Name="select4" Grid.Column="1" MinWidth="170" MaxWidth="300" HorizontalAlignment="Stretch" Tag="Target partition" KeyboardNavigation.TabIndex="117">
                                        <compat:CompatComboBoxItem Content="boot" />
                                        <compat:CompatComboBoxItem Content="init_boot" />
                                        <compat:CompatComboBoxItem Content="super" />
                                        <compat:CompatComboBoxItem Content="system" />
                                        <compat:CompatComboBoxItem Content="vbmeta" />
                                        <compat:CompatComboBoxItem Content="recovery" />
                                    </compat:CompatComboBox>
                                </Grid>
                            </Grid>
                        </compat:CompatTabItem>
                        <compat:CompatTabItem x:Name="tabPage3" Header="Boot Mode">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
