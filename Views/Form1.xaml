                        <compat:CompatComboBoxItem Content="Simulated Device: System Mode" />
                    </compat:CompatComboBox>
                    <compat:CompatGroupBox x:Name="uiGroupBox3" Grid.Row="2" Grid.Column="2" Margin="0,8,0,10" KeyboardNavigation.TabIndex="20" Header="Device">
