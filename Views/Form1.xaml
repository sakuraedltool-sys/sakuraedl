                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <compat:CompatLabel x:Name="uiLabel9" Grid.Row="0" Grid.Column="0" Height="22" KeyboardNavigation.TabIndex="19" FontFamily="Segoe UI" FontSize="10.5" Foreground="{DynamicResource ThemeForegroundBrush}" Content="Brand: Waiting for connection" />
                            <compat:CompatLabel x:Name="uiLabel11" Grid.Row="0" Grid.Column="1" Height="22" KeyboardNavigation.TabIndex="20" FontFamily="Segoe UI" FontSize="10.5" Foreground="{DynamicResource ThemeForegroundBrush}" Content="Chip: Waiting for connection" />
                            <compat:CompatLabel x:Name="uiLabel12" Grid.Row="1" Grid.ColumnSpan="2" Height="22" KeyboardNavigation.TabIndex="21" FontFamily="Segoe UI" FontSize="10.5" Background="Transparent" Foreground="{DynamicResource ThemeForegroundBrush}" Content="Version: Waiting for connection" />
                            <compat:CompatLabel x:Name="uiLabel10" Grid.Row="2" Grid.Column="0" Height="22" KeyboardNavigation.TabIndex="22" FontFamily="Segoe UI" FontSize="10.5" Foreground="{DynamicResource ThemeForegroundBrush}" Content="Chip Serial: Waiting for connection" />
                            <compat:CompatLabel x:Name="uiLabel3" Grid.Row="2" Grid.Column="1" Height="22" KeyboardNavigation.TabIndex="23" FontFamily="Segoe UI" FontSize="10.5" Foreground="{DynamicResource ThemeForegroundBrush}" Content="Model: Waiting for connection" />
                            <compat:CompatLabel x:Name="uiLabel14" Grid.Row="3" Grid.Column="0" Height="22" KeyboardNavigation.TabIndex="25" FontFamily="Segoe UI" FontSize="10.5" Foreground="{DynamicResource ThemeForegroundBrush}" Content="Model: Waiting for connection" />
                            <compat:CompatLabel x:Name="uiLabel13" Grid.Row="3" Grid.Column="1" Height="22" KeyboardNavigation.TabIndex="24" FontFamily="Segoe UI" FontSize="10.5" Foreground="{DynamicResource ThemeForegroundBrush}" Content="Storage: Waiting for connection" />
                        </Grid>
                    </compat:CompatGroupBox>
                    <TabControl x:Name="tabs1" Grid.Row="2" Grid.Column="0" Grid.RowSpan="2" Margin="0,8,10,8" KeyboardNavigation.TabIndex="15" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <compat:CompatTabItem x:Name="tabPage1" Header="MDM - ADB">
                            <Grid Margin="10">
                                <Border CornerRadius="12"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource ThemeInsetBorderBrush}"
                                            Background="{DynamicResource ThemeInsetBrush}">
                                    <compat:CompatLabel x:Name="labelDevRoot"
                                               KeyboardNavigation.TabIndex="0"
                                               FontFamily="Segoe UI"
                                               FontSize="24"
                                               Foreground="Silver"
                                               HorizontalContentAlignment="Center"
                                               VerticalContentAlignment="Center"
                                               Content="Under Development..." />
                                </Border>
                            </Grid>
                        </compat:CompatTabItem>
                        <compat:CompatTabItem x:Name="tabPage2" Header="Qualcomm Platform">
