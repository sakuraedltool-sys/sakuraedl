<Window x:Class="SakuraEDL.Views.Form1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:compat="clr-namespace:SakuraEDL.Views.Controls"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SakuraEDL v3.0"
        Width="1430"
        Height="900"
        MinWidth="980"
        MinHeight="640"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Style="{DynamicResource {x:Type Window}}"
        Background="Transparent"
        FontFamily="Segoe UI"
        FontSize="10.5">

    <Grid x:Name="MainFormRoot"
          ClipToBounds="True"
          Background="{DynamicResource ThemeHostBackgroundBrush}"
          RenderTransformOrigin="0.5,0.5">

        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform ScaleX="1" ScaleY="1" />
                <SkewTransform AngleX="0" AngleY="0" />
                <RotateTransform Angle="0" />
                <TranslateTransform X="0" Y="0" />
            </TransformGroup>
        </Grid.RenderTransform>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="841*"/>
            <ColumnDefinition Width="512*"/>
            <ColumnDefinition Width="77*"/>
        </Grid.ColumnDefinitions>
        <Ellipse Width="520"
                 Height="520"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-120,-160,0,0"
                 Fill="{DynamicResource ThemeOrbBrush}"
                 IsHitTestVisible="False"
                 Opacity="0.38" />
        <Ellipse Width="460"
                 Height="460"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-140,-170"
                 Fill="{DynamicResource ThemeOrbBrush}"
                 IsHitTestVisible="False"
                 Opacity="0.28" Grid.Column="1" Grid.ColumnSpan="2" />
        <Border Margin="10"
                Padding="10"
                    CornerRadius="16"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ThemeRaisedBorderBrush}"
                    Background="{DynamicResource ThemeShellGlassBrush}"
                    Effect="{DynamicResource ThemeFrameShadow}"
                    Opacity="1" Grid.ColumnSpan="3">
            <Border.RenderTransform>
                <TranslateTransform Y="0" />
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0"
                                                 To="1"
                                                 Duration="0:0:0.42" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 From="18"
                                                 To="0"
                                                 Duration="0:0:0.42" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
            <Border CornerRadius="13"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ThemeInsetBorderBrush}"
                        Background="{DynamicResource ThemeWindowBackgroundBrush}">
                <Grid x:Name="MainShellGrid" Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.4*" MinWidth="520" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="1.25*" MinWidth="340" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="58" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="34" />
                    </Grid.RowDefinitions>
                    <Image Grid.RowSpan="6"
                           Grid.ColumnSpan="3"
                           Panel.ZIndex="500"
                           Width="780"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           Opacity="0.1"
                           Source="/Assets/aat_logo.png"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Effect>
                            <DropShadowEffect Color="#88000000"
                                              BlurRadius="38"
                                              ShadowDepth="0"
                                              Opacity="0.42" />
                        </Image.Effect>
                    </Image>
                    <GridSplitter Grid.Column="1"
                                       Grid.Row="1"
                                       Grid.RowSpan="4"
                                      Width="8"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      Background="{DynamicResource ThemeInsetBrush}"
                                      ShowsPreview="True" />
                    <!-- Auto-generated from Form1.Designer.cs -->
                    <Grid Grid.Row="4" Grid.Column="0" Margin="0,6,10,4">
                        <ProgressBar x:Name="uiProcessBar1" KeyboardNavigation.TabIndex="4" FontFamily="Segoe UI" FontSize="10.5" Minimum="0" Maximum="100" Value="0" />
                        <TextBlock Margin="0,0,8,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Semibold"
                                       FontSize="11"
                                       Foreground="{DynamicResource ThemeForegroundBrush}"
                                       Text="{Binding ElementName=uiProcessBar1, Path=Value, StringFormat={}{0:0}%}" />
                    </Grid>
