                                    <compat:CompatTextBox x:Name="uiTextBox1" Grid.Column="0" Margin="0,0,8,0" Tag="Fastboot package/payload path" KeyboardNavigation.TabIndex="15" FontFamily="Segoe UI" FontSize="10.5" />
                                    <compat:CompatButton x:Name="button9" Grid.Column="1" MinWidth="132" KeyboardNavigation.TabIndex="100" Content="Browse" />
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
