                                    <compat:CompatCheckBox x:Name="checkbox14" Grid.Column="1" Margin="0,0,10,0" KeyboardNavigation.TabIndex="118" VerticalAlignment="Center" Content="Auto Detect" />
                                    <compat:CompatRadioButton x:Name="radio3" Grid.Column="2" Margin="0,0,10,0" KeyboardNavigation.TabIndex="119" VerticalAlignment="Center" Content="UFS" />
