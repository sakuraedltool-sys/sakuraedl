<Window x:Class="SakuraEDL.Views.SplashForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SakuraEDL Splash"
        Width="620"
        Height="360"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        Background="{DynamicResource ThemeHostBackgroundBrush}"
        FontFamily="Segoe UI"
        FontSize="10.5"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown" AllowsTransparency="True">
    <Grid ClipToBounds="True">
        <Ellipse Width="300"
                 Height="300"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-90,-110,0,0"
                 Fill="{DynamicResource ThemeOrbBrush}"
                 IsHitTestVisible="False"
                 Opacity="0.75" />
        <Ellipse Width="260"
                 Height="260"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-90,-100"
                 Fill="{DynamicResource ThemeOrbBrush}"
                 IsHitTestVisible="False"
                 Opacity="0.62" />

        <Border
                Padding="8"
                CornerRadius="16"
                BorderThickness="1"
                BorderBrush="{DynamicResource ThemeRaisedBorderBrush}"
                Background="{DynamicResource ThemeShellGlassBrush}"
                Effect="{DynamicResource ThemeFrameShadow}">
            <Border CornerRadius="12"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ThemeInsetBorderBrush}"
                    Background="{DynamicResource ThemeWindowBackgroundBrush}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="54" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            CornerRadius="10"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ThemeBorderBrush}"
                            Background="{DynamicResource ThemeSurfaceBrush}"
                            Padding="12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe UI Semibold"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ThemeForegroundBrush}"
                                           Text="Android Auth Tool" />
                                <TextBlock Margin="10,9,0,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                           Text="Initializing Secure Device Modules..." />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Padding="10,4"
                                    CornerRadius="7"
                                    Background="{DynamicResource ThemeInsetBrush}"
                                    BorderBrush="{DynamicResource ThemeInsetBorderBrush}"
                                    BorderThickness="1">
                                <TextBlock FontSize="12"
                                           Foreground="{DynamicResource ThemeAccentBrush}"
                                           Text="AAT" />
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Canvas Grid.Row="0"
                                Name="SpinnerCanvas"
                                Width="64"
                                Height="64"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0,6,0,0" />

                        <TextBlock Grid.Row="1"
                                   Name="LogoLabel"
                                   Margin="0,12,0,0"
                                   HorizontalAlignment="Center"
                                   Opacity="0"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeAccentBrush}"
                                   Text="Android Auth Tool" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                   Text="Professional Device Service Panel" />
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="0,12,0,0"
                            Padding="10,6"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ThemeInsetBorderBrush}"
                            Background="{DynamicResource ThemeInsetBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Name="StatusLabel"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeForegroundBrush}"
                                       Text="initialization..." />
                            <TextBlock Grid.Column="1"
                                       Margin="14,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                       Text="Press Esc to close" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3"
                          Margin="0,10,0,0">
                        <ProgressBar Name="ProgressBar1"
                                     Height="24"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0" />
                        <TextBlock Margin="0,0,8,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="11"
                                   Foreground="{DynamicResource ThemeForegroundBrush}"
                                   Text="{Binding ElementName=ProgressBar1, Path=Value, StringFormat={}{0:0}%}" />
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
